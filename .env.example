# 服务配置
APP_HOST=127.0.0.1
APP_PORT=8080
WEB_DIR=web
DATA_DIR=data
DASHBOARD_TITLE=模型连通性
# 公开绑定 APP_HOST=0.0.0.0 / :: 时必须设置，用于保护 POST /api/check。
ADMIN_TOKEN=

# 探测配置
TIMEOUT_SECONDS=30
MODEL_LIST_TIMEOUT_SECONDS=20
SLOW_THRESHOLD_MS=8000
CONCURRENCY=3
PROVIDER_CONCURRENCY=1
MAX_MODELS_PER_PROVIDER=0
SKIP_MODELS=
PROBE_PROMPT=只回复 OK 两个字母。
PROBE_SYSTEM_PROMPT=你是一个模型连通性探针。请只回复 OK，不要解释。

# 历史与显示
ENABLE_HISTORY=true
SHOW_CURVE_CHART=true
STATS_WINDOW_DAYS=7
HISTORY_SIZE=30
MAX_HISTORY_RECORDS=500
SHOW_ERROR_DETAIL=true
THEME_MODE=auto
DAY_MODE_START_HOUR=8
DAY_MODE_END_HOUR=18

# 定时检测。0 表示关闭；例如 2 和 5 表示每 2-5 小时随机检测一次。
AUTO_CHECK_INTERVAL_MIN_HOURS=0
AUTO_CHECK_INTERVAL_MAX_HOURS=0
AUTO_CHECK_RUN_ON_START=false

# OpenAI 兼容提供商示例
PROVIDER_1_ID=openai-main
PROVIDER_1_NAME=OpenAI
PROVIDER_1_TYPE=openai
PROVIDER_1_BASE_URL=https://api.openai.com/v1
PROVIDER_1_API_KEY=sk-xxx
PROVIDER_1_MODELS=gpt-4o-mini,gpt-4.1-mini
PROVIDER_1_ENABLED=true

# 本地 Ollama OpenAI 兼容模式示例
# PROVIDER_2_ID=ollama-local
# PROVIDER_2_NAME=Ollama
# PROVIDER_2_TYPE=ollama
# PROVIDER_2_BASE_URL=http://127.0.0.1:11434/v1
# PROVIDER_2_API_KEY=
# PROVIDER_2_MODELS=llama3.1
# PROVIDER_2_ENABLED=true
